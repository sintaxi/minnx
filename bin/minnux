#!/usr/bin/env node

/**
 * Module dependencies.
 */

var Group = require('../');
var minimist = require('minimist');
var pkg = require('../package');
var spawn = require('child_process').spawnSync;
var path = require('path');
var s = require('printf');
var ms = require('ms');
var fs = require('fs');
var mkdir = function(p) { fs.mkdirSync(p, { recursive: true }); };

// parse args

var argv = minimist(process.argv.slice(2), {
  string: ['config'],
  boolean: ['json', 'help', 'version'],
  alias: { c: 'config', j: 'json', h: 'help', v: 'version' },
  default: { config: 'mx.conf' }
});

// version

if (argv.version) {
  console.log(pkg.version);
  process.exit(0);
}

// help

if (argv.help) {
  console.log();
  console.log('  Usage: minnux [options] [command] [names]');
  console.log();
  console.log('  Options:');
  console.log();
  console.log('    -c, --config <path>  load configuration [./mx.conf]');
  console.log('    -j, --json           output json');
  console.log('    -v, --version        output version');
  console.log('    -h, --help           output help');
  console.log();
  console.log('  Commands:');
  console.log();
  console.log('    status           output process status (default)');
  console.log('    start   [names]  start all or specified processes');
  console.log('    stop    [names]  stop all or specified processes');
  console.log('    restart [names]  restart all or specified processes');
  console.log('    chat    [name]   attach to a running process');
  console.log('    send    [name] <message>  send a message to one or all agents');
  console.log('    ask     [name] <message>  ask one or all agents and print response');
  console.log();
  process.exit(0);
}

// check for tmux

try {
  require('child_process').execSync('tmux -V', { stdio: 'ignore' });
} catch (e) {
  console.error('minnux requires tmux. Install with: brew install tmux');
  process.exit(1);
}

// command

var cmd = argv._.shift() || 'status';

// config

var confFile;
try {
  confFile = fs.readFileSync(argv.config, 'utf8');
} catch (err) {
  console.error('cannot read config file "' + argv.config + '"');
  process.exit(1);
}
var conf = Group.parseConfig(confFile);

// resolve agent dirs before chdir (relative to cwd, not config dir)
Object.keys(conf.processes).forEach(function(key) {
  var proc = conf.processes[key];
  if (proc.dir) {
    proc.dir = path.resolve(proc.dir);
  }
});

// cd

var dir = path.dirname(argv.config);
process.chdir(dir);

// ensure log dir exists

conf.logs = conf.logs || 'logs';
mkdir(conf.logs);

// group

var group = new Group(conf);

// commands

switch (cmd) {
  case 'stop': return stop(argv._);
  case 'start': return start(argv._);
  case 'restart': return restart(argv._);
  case 'chat': return chat(argv._[0]);
  case 'send': return send(argv._);
  case 'ask': return ask(argv._);
  case 'status': return argv.json ? jsonstatus() : status();
  default:
    console.error('unknown command "' + cmd + '", run `minnux --help` for usage');
    process.exit(1);
}

/**
 * Start procs.
 */

function start(procs, fn) {
  if (!fn) console.log();

  group.on('start', function(proc){
    console.log(s('\033[36m%15s\033[m : starting', proc.name));
  });

  group.on('running', function(proc){
    console.log(s('\033[32m%15s\033[m : running', proc.name));
  });

  group.start(procs, function(err){
    if (err) throw err;
    if (fn) return fn();
    console.log();
  });
}

/**
 * Stop procs.
 */

function stop(procs, fn) {
  console.log();

  group.on('stopping', function(proc){
    console.log(s('\033[36m%15s\033[m : stopping', proc.name));
  });

  group.stop(procs, null, function(err){
    if (err) throw err;
    if (fn) return fn();
    console.log();
  });
}

/**
 * Restart procs.
 */

function restart(procs) {
  stop(procs, function(){
    console.log();
    // re-hydrate group state after stop
    group.windowInfo = group.queryWindows();
    group.procs = group.processes();
    start(procs, function(){
      console.log();
    });
  });
}

/**
 * Attach to a running process.
 */

function chat(name) {
  var session = group.session || 'minnux';

  // no name — attach to the session (navigate windows freely)
  if (!name) {
    spawn('tmux', ['attach', '-t', session], { stdio: 'inherit' });
    return;
  }

  // validate the name exists in config
  var proc = group.procs.filter(function(p) { return p.name === name; })[0];
  if (!proc) {
    console.error('unknown process "' + name + '"');
    process.exit(1);
  }

  if (!proc.alive()) {
    console.error('"' + name + '" is not running');
    process.exit(1);
  }

  var target = proc.target();
  spawn('tmux', ['attach', '-t', target], { stdio: 'inherit' });
}

/**
 * Send a message to a running process.
 */

function send(args) {
  var exec = require('child_process').execSync;

  // determine if first arg is a process name or part of the message
  var resolved = resolveTarget(args);
  if (!resolved.message) {
    console.error('usage: minnux send [name] <message>');
    process.exit(1);
  }

  var targets = resolved.procs;
  if (!targets.length) {
    console.error('no running pi agents found');
    process.exit(1);
  }

  targets.forEach(function(proc) {
    var target = proc.target();
    exec('tmux send-keys -t ' + shellQuote(target) + ' ' + shellQuote(resolved.message) + ' Enter');
  });
}

/**
 * Send a message and print the streaming response.
 */

function ask(args) {
  var net = require('net');

  // determine if first arg is a process name or part of the message
  var resolved = resolveTarget(args);
  if (!resolved.message) {
    console.error('usage: minnux ask [name] <message>');
    process.exit(1);
  }

  var targets = resolved.procs;
  if (!targets.length) {
    console.error('no running pi agents found');
    process.exit(1);
  }

  var broadcast = targets.length > 1;
  var nameW = 0;
  if (broadcast) {
    targets.forEach(function(p) {
      if (p.name.length > nameW) nameW = p.name.length;
    });
  }

  var pending = targets.length;

  targets.forEach(function(proc) {
    var socketPath = path.resolve(path.join('sockets', proc.name + '.sock'));
    var client = net.connect(socketPath, function() {
      client.write(JSON.stringify({ type: 'prompt', message: resolved.message }) + '\n');
    });

    var buf = '';
    var first = true;
    client.on('data', function(chunk) {
      buf += chunk.toString();
      var lines = buf.split('\n');
      buf = lines.pop();

      lines.forEach(function(line) {
        if (!line.trim()) return;
        try {
          var event = JSON.parse(line);
          if (event.type === 'text_delta') {
            if (broadcast) {
              // buffer the full response, print on done
              if (!proc._response) proc._response = '';
              proc._response += event.delta;
            } else {
              process.stdout.write(event.delta);
            }
          } else if (event.type === 'done') {
            if (broadcast && proc._response) {
              var lines = proc._response.trim().split('\n');
              lines.forEach(function(line, i) {
                if (i === 0) {
                  console.log(s('\033[32m%' + nameW + 's\033[m : %s', proc.name, line));
                } else {
                  console.log(s('%' + nameW + 's   %s', '', line));
                }
              });
            } else if (!broadcast) {
              process.stdout.write('\n');
            }
            client.end();
            pending--;
            if (pending === 0) process.exit(0);
          } else if (event.type === 'error') {
            console.error(proc.name + ': ' + event.message);
            client.end();
            pending--;
            if (pending === 0) process.exit(1);
          }
        } catch (e) {}
      });
    });

    client.on('error', function(err) {
      if (err.code === 'ENOENT') {
        console.error('"' + proc.name + '" does not have a socket (is it a pi agent?)');
      } else {
        console.error(proc.name + ': ' + err.message);
      }
      pending--;
      if (pending === 0) process.exit(1);
    });
  });
}

/**
 * Resolve target processes from args.
 * If first arg matches a process name, target that one.
 * Otherwise broadcast to all alive pi agents (those with sockets).
 */

function resolveTarget(args) {
  if (!args.length) return { procs: [], message: '' };

  var first = args[0];
  var proc = group.procs.filter(function(p) { return p.name === first; })[0];

  // first arg is a known process name
  if (proc) {
    var message = args.slice(1).join(' ');
    if (!proc.alive()) {
      console.error('"' + first + '" is not running');
      process.exit(1);
    }
    return { procs: [proc], message: message };
  }

  // broadcast to all alive pi agents with sockets
  var message = args.join(' ');
  var targets = group.procs.filter(function(p) {
    if (!p.alive()) return false;
    try {
      var socketPath = path.resolve(path.join('sockets', p.name + '.sock'));
      require('fs').accessSync(socketPath);
      return true;
    } catch (e) {
      return false;
    }
  });

  return { procs: targets, message: message };
}

/**
 * Shell-quote a string.
 */

function shellQuote(str) {
  return "'" + str.replace(/'/g, "'\\''") + "'";
}

/**
 * Output json status.
 */

function jsonstatus() {
  var procs = {};

  group.procs.forEach(function(proc){
    var state = proc.state();

    var uptime = 'alive' == state
      ? Date.now() - proc.mtime()
      : 0;

    procs[proc.name] = {
      state: state,
      pid: proc.pid,
      uptime: uptime,
      stats: proc.stats()
    };
  });

  console.log(JSON.stringify(procs, null, 2));
}

/**
 * Output process status.
 */

function indicator(procState, agentState) {
  // process-level states
  if (procState === 'standby') return '\033[90m○\033[m';
  if (procState === 'dead')    return '\033[31m●\033[m';

  // agent-level states (process is alive)
  switch (agentState) {
    case 'working': return '\033[32m●\033[m';
    case 'error':   return '\033[31m●\033[m';
    case 'aborted': return '\033[33m●\033[m';
    case 'stuck':   return '\033[31m○\033[m';
    case 'idle':    return '\033[90m●\033[m';
    default:        return '\033[90m●\033[m';
  }
}

function status() {
  // first pass: collect row data and measure column widths
  var rows = [];
  var widths = { name: 0, model: 0, uptime: 0, cost: 0 };

  group.procs.forEach(function(proc) {
    var state = proc.state();
    var stats = proc.stats();
    var row = {
      name: proc.name,
      model: (stats && stats.model) ? stats.model : '',
      state: state,
      agentState: (stats && stats.state) ? stats.state : null,
      uptime: state === 'alive' ? ms(Date.now() - proc.mtime(), { long: true }) : '',
      cost: (stats && stats.cost != null) ? '$' + stats.cost.toFixed(4) : ''
    };
    rows.push(row);

    for (var key in widths) {
      if (row[key] && row[key].length > widths[key]) widths[key] = row[key].length;
    }
  });

  // second pass: render with padding
  var nameW = Math.max(widths.name, 15);

  console.log();
  rows.forEach(function(row) {
    var name = s('%' + nameW + 's', row.name);
    var nameColor = row.state === 'standby' ? '\033[33m' : row.state === 'dead' ? '\033[31m' : '\033[32m';
    var parts = [nameColor + name + '\033[m'];

    if (widths.model > 0) {
      parts.push('\033[90m' + s('%-' + widths.model + 's', row.model) + '\033[m');
    }

    switch (row.state) {
      case 'standby':
        parts.push(row.state);
        break;
      case 'dead':
        parts.push(row.state);
        break;
      case 'alive':
        var dot = indicator(row.state, row.agentState);
        parts.push('\033[32m' + row.state + '\033[m');
        parts.push(dot);
        parts.push(s('%-' + widths.uptime + 's', row.uptime));
        if (widths.cost > 0 && row.cost) parts.push(row.cost);
        break;
    }

    console.log(parts.join(' \033[90m:\033[m '));
  });
  console.log();
}
