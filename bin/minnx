#!/usr/bin/env node

/**
 * Module dependencies.
 */

var Group = require('../');
var minimist = require('minimist');
var pkg = require('../package');
var spawn = require('child_process').spawnSync;
var path = require('path');
var s = require('printf');
var ms = require('ms');
var fs = require('fs');
var mkdir = function(p) { fs.mkdirSync(p, { recursive: true }); };

// parse args

var argv = minimist(process.argv.slice(2), {
  string: ['config'],
  boolean: ['json', 'help', 'version'],
  alias: { c: 'config', j: 'json', h: 'help', v: 'version' },
  default: { config: 'minnx.conf' }
});

// version

if (argv.version) {
  console.log(pkg.version);
  process.exit(0);
}

// help

if (argv.help) {
  console.log();
  console.log('  Usage: minnx [options] [command] [names]');
  console.log();
  console.log('  Options:');
  console.log();
  console.log('    -c, --config <path>  load configuration [./minnx.conf]');
  console.log('    -j, --json           output json');
  console.log('    -v, --version        output version');
  console.log('    -h, --help           output help');
  console.log();
  console.log('  Commands:');
  console.log();
  console.log('    status           output process status (default)');
  console.log('    start   [names]  start all or specified processes');
  console.log('    stop    [names]  stop all or specified processes');
  console.log('    restart [names]  restart all or specified processes');
  console.log('    chat    [name]   attach to a running process');
  console.log('    send    <name> <message>  send a message to a process');
  console.log('    ask     <name> <message>  send a message and print response');
  console.log();
  process.exit(0);
}

// check for tmux

try {
  require('child_process').execSync('tmux -V', { stdio: 'ignore' });
} catch (e) {
  console.error('minnx requires tmux. Install with: brew install tmux');
  process.exit(1);
}

// command

var cmd = argv._.shift() || 'status';

// config

var confFile;
try {
  confFile = fs.readFileSync(argv.config, 'utf8');
} catch (err) {
  console.error('cannot read config file "' + argv.config + '"');
  process.exit(1);
}
var conf = Group.parseConfig(confFile);

// cd

var dir = path.dirname(argv.config);
process.chdir(dir);

// ensure log dir exists

conf.logs = conf.logs || 'logs';
mkdir(conf.logs);

// group

var group = new Group(conf);

// commands

switch (cmd) {
  case 'stop': return stop(argv._);
  case 'start': return start(argv._);
  case 'restart': return restart(argv._);
  case 'chat': return chat(argv._[0]);
  case 'send': return send(argv._[0], argv._.slice(1).join(' '));
  case 'ask': return ask(argv._[0], argv._.slice(1).join(' '));
  case 'status': return argv.json ? jsonstatus() : status();
  default:
    console.error('unknown command "' + cmd + '", run `minnx --help` for usage');
    process.exit(1);
}

/**
 * Start procs.
 */

function start(procs, fn) {
  if (!fn) console.log();

  group.on('start', function(proc){
    console.log(s('\033[36m%15s\033[m : starting', proc.name));
  });

  group.on('running', function(proc){
    console.log(s('\033[32m%15s\033[m : running', proc.name));
  });

  group.start(procs, function(err){
    if (err) throw err;
    if (fn) return fn();
    console.log();
  });
}

/**
 * Stop procs.
 */

function stop(procs, fn) {
  console.log();

  group.on('stopping', function(proc){
    console.log(s('\033[36m%15s\033[m : stopping : %s', proc.name, proc.pid || 0));
  });

  group.on('stop', function(proc){
    console.log(s('\033[36m%15s\033[m : standby : %s', proc.name, proc.pid || 0));
  });

  group.stop(procs, null, function(err){
    if (err) throw err;
    if (fn) return fn();
    console.log();
  });
}

/**
 * Restart procs.
 */

function restart(procs) {
  stop(procs, function(){
    start(procs, function(){
      console.log(s('\033[36m%15s\033[m : complete', 'restart'));
      console.log();
    });
  });
}

/**
 * Attach to a running process.
 */

function chat(name) {
  var session = group.session || 'minnx';

  // no name — attach to the session (navigate windows freely)
  if (!name) {
    spawn('tmux', ['attach', '-t', session], { stdio: 'inherit' });
    return;
  }

  // validate the name exists in config
  var proc = group.procs.filter(function(p) { return p.name === name; })[0];
  if (!proc) {
    console.error('unknown process "' + name + '"');
    process.exit(1);
  }

  if (!proc.alive()) {
    console.error('"' + name + '" is not running');
    process.exit(1);
  }

  var target = session + ':' + name;
  spawn('tmux', ['attach', '-t', target], { stdio: 'inherit' });
}

/**
 * Send a message to a running process.
 */

function send(name, message) {
  var session = group.session || 'minnx';

  if (!name || !message) {
    console.error('usage: minnx send <name> <message>');
    process.exit(1);
  }

  var proc = group.procs.filter(function(p) { return p.name === name; })[0];
  if (!proc) {
    console.error('unknown process "' + name + '"');
    process.exit(1);
  }

  if (!proc.alive()) {
    console.error('"' + name + '" is not running');
    process.exit(1);
  }

  var target = session + ':' + name;
  var exec = require('child_process').execSync;
  exec('tmux send-keys -t ' + shellQuote(target) + ' ' + shellQuote(message) + ' Enter');
}

/**
 * Send a message and print the streaming response.
 */

function ask(name, message) {
  var net = require('net');
  var session = group.session || 'minnx';

  if (!name || !message) {
    console.error('usage: minnx ask <name> <message>');
    process.exit(1);
  }

  var proc = group.procs.filter(function(p) { return p.name === name; })[0];
  if (!proc) {
    console.error('unknown process "' + name + '"');
    process.exit(1);
  }

  if (!proc.alive()) {
    console.error('"' + name + '" is not running');
    process.exit(1);
  }

  var socketPath = path.resolve(path.join('sockets', name + '.sock'));
  var client = net.connect(socketPath, function() {
    client.write(JSON.stringify({ type: 'prompt', message: message }) + '\n');
  });

  var buf = '';
  client.on('data', function(chunk) {
    buf += chunk.toString();
    var lines = buf.split('\n');
    buf = lines.pop();

    lines.forEach(function(line) {
      if (!line.trim()) return;
      try {
        var event = JSON.parse(line);
        if (event.type === 'text_delta') {
          process.stdout.write(event.delta);
        } else if (event.type === 'done') {
          process.stdout.write('\n');
          client.end();
        } else if (event.type === 'error') {
          console.error(event.message);
          client.end();
          process.exit(1);
        }
      } catch (e) {}
    });
  });

  client.on('error', function(err) {
    if (err.code === 'ENOENT') {
      console.error('"' + name + '" does not have a socket (is it a pi agent?)');
    } else {
      console.error('connection error: ' + err.message);
    }
    process.exit(1);
  });
}

/**
 * Shell-quote a string.
 */

function shellQuote(str) {
  return "'" + str.replace(/'/g, "'\\''") + "'";
}

/**
 * Output json status.
 */

function jsonstatus() {
  var procs = {};

  group.procs.forEach(function(proc){
    var state = proc.state();

    var uptime = 'alive' == state
      ? Date.now() - proc.mtime()
      : 0;

    procs[proc.name] = {
      state: state,
      pid: proc.pid,
      uptime: uptime,
      stats: proc.stats()
    };
  });

  console.log(JSON.stringify(procs, null, 2));
}

/**
 * Output process status.
 */

function status() {
  console.log();
  group.procs.forEach(function(proc){
    var state = proc.state();

    switch (state) {
      case 'standby':
        console.log(s('\033[33m%15s\033[m : %s', proc.name, state));
        break;
      case 'alive':
        var uptime = ms(Date.now() - proc.mtime(), { long: true });
        var stats = proc.stats();
        if (stats && stats.model) {
          var cost = stats.cost ? ' : $' + stats.cost.toFixed(4) : '';
          console.log(s('\033[32m%15s\033[m : \033[90m%s\033[m : %s : %s : %s%s', proc.name, stats.model, proc.state(), proc.pid, uptime, cost));
        } else {
          console.log(s('\033[32m%15s\033[m : %s : %s : %s', proc.name, proc.state(), proc.pid, uptime));
        }
        break;
      case 'dead':
        console.log(s('\033[31m%15s\033[m : %s', proc.name, proc.state(), proc.pid || 0));
        break;
    }
  });
  console.log();
}
